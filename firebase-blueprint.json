{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "chatId", "role", "content", "createdAt"]
    },
    "Image": {
      "title": "Image",
      "description": "A generated image",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "aspectRatio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "aspectRatio", "imageUrl", "createdAt"]
    },
    "Transcription": {
      "title": "Transcription",
      "description": "A transcribed audio log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages in a chat"
    },
    "/images/{imageId}": {
      "schema": { "$ref": "#/entities/Image" },
      "description": "Generated images"
    },
    "/transcriptions/{transcriptionId}": {
      "schema": { "$ref": "#/entities/Transcription" },
      "description": "Transcribed audio logs"
    }
  }
}
